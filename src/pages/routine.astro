---
import "../style.scss";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>life routine</title>
</head>
<body>
    <div class="container">
        <a href="#top" id="back-to-top" class="back-to-top">^</a>
        <a href="/" class="link">← workout plan</a>
        
        <h1>life routine</h1>

        <section id="daily-checklist" class="routine-section">
            <h2>daily routine</h2>
            <div class="checklist-container">
                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="brush-teeth-morning" id="check-brush-teeth-morning">
                    <label for="check-brush-teeth-morning" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="brush-teeth-morning">brush teeth morning</span>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="gym" id="check-gym">
                    <label for="check-gym" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="gym">gym (1 hour)</span>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="gym" id="check-gym">
                    <label for="check-gym" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="gym">walk Mia</span>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="breathwork" id="check-breathwork">
                    <label for="check-breathwork" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="breathwork">8 minutes breathwork</span>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="journal" id="check-journal">
                    <label for="check-journal" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="journal">journal</span>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="meal-1" id="check-meal-1">
                    <label for="check-meal-1" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="meal-1">meal 1</span>
                        <details class="task-details">
                            <summary>details</summary>
                            <ul class="ingredients-list">
                                <li>4 eggs</li>
                                <li>banana</li>
                                <li>spinach/kale (~550 cal)</li>
                            </ul>
                        </details>
                    </div>
                </div>

                <div class="checklist-item task-item task-item-orange">
                    <input type="checkbox" data-task="timeclick" id="check-timeclick">
                    <label for="check-timeclick" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="timeclick">build TimeClick demo flow</span>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="pilates" id="check-pilates">
                    <label for="check-pilates" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="pilates">1 pilates class</span>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="flexibility-after-pilates" id="check-flexibility-after-pilates">
                    <label for="check-flexibility-after-pilates" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="flexibility-after-pilates">10 minutes flexibility after pilates</span>
                        <details class="task-details">
                            <summary>stretches</summary>
                            <ol class="stretch-list">
                                <li>couch stretch</li>
                                <li>pancake stretch</li>
                                <li>deep squat hold</li>
                            </ol>
                        </details>
                    </div>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="meal-2" id="check-meal-2">
                    <label for="check-meal-2" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="meal-2">meal 2</span>
                        <details class="task-details">
                            <summary>details</summary>
                            <ul class="ingredients-list">
                                <li>greek yogurt</li>
                                <li>berries</li>
                                <li>flax seeds</li>
                                <li>almonds (~500 cal)</li>
                            </ul>
                        </details>
                    </div>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="clean-kitchen" id="check-clean-kitchen">
                    <label for="check-clean-kitchen" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="clean-kitchen">clean kitchen</span>
                </div>

                <div class="checklist-item task-item task-item-orange">
                    <input type="checkbox" data-task="write-blog-2" id="check-write-blog-2">
                    <label for="check-write-blog-2" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="write-blog-2">write blog 4</span>
                </div>
                
                <div class="checklist-item task-item task-item-orange">
                    <input type="checkbox" data-task="write-blog-2" id="check-write-blog-2">
                    <label for="check-write-blog-2" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="write-blog-2">write social media post 2</span>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="meal-3" id="check-meal-3">
                    <label for="check-meal-3" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="meal-3">meal 3</span>
                        <details class="task-details">
                            <summary>details</summary>
                            <ul class="ingredients-list">
                                <li>ground beef</li>
                                <li>sweet potato</li>
                                <li>olive oil (~650 cal)</li>
                            </ul>
                        </details>
                    </div>
                </div>

                <div class="checklist-item task-item task-item-orange">
                    <input type="checkbox" data-task="habit-app" id="check-habit-app">
                    <label for="check-habit-app" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="habit-app">work on habit app</span>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="meal-4" id="check-meal-4">
                    <label for="check-meal-4" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="meal-4">meal 4</span>
                        <details class="task-details">
                            <summary>details</summary>
                            <ul class="ingredients-list">
                                <li>huel + peanut butter (~500 cal)</li>
                            </ul>
                        </details>
                    </div>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="meal-5" id="check-meal-5">
                    <label for="check-meal-5" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="meal-5">meal 5</span>
                        <details class="task-details">
                            <summary>details</summary>
                            <ul class="ingredients-list">
                                <li>cottage cheese</li>
                                <li>banana or berries</li>
                                <li>protein shake (~500 cal)</li>
                            </ul>
                        </details>
                    </div>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="brush-teeth-night" id="check-brush-teeth-night">
                    <label for="check-brush-teeth-night" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="brush-teeth-night">brush teeth night</span>
                </div>

                <div class="checklist-item task-item">
                    <input type="checkbox" data-task="floss" id="check-floss">
                    <label for="check-floss" class="checkmark"></label>
                    <span class="task-label" contenteditable="true" data-task="floss">floss at night</span>
                </div>

                <div class="checklist-item task-item task-with-details">
                    <input type="checkbox" data-task="flexibility-before-bed" id="check-flexibility-before-bed">
                    <label for="check-flexibility-before-bed" class="checkmark"></label>
                    <div class="task-content">
                        <span class="task-label" contenteditable="true" data-task="flexibility-before-bed">10 minutes flexibility before bed</span>
                        <details class="task-details">
                            <summary>stretches</summary>
                            <ol class="stretch-list">
                                <li>jefferson curl</li>
                                <li>thoracic opener</li>
                                <li>butterfly</li>
                            </ol>
                        </details>
                    </div>
                </div>
            </div>
        </section>
    </div>
</body>
</html>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // scroll to top
        window.addEventListener("scroll", () => {
            const button = document.getElementById("back-to-top");
            if (button) {
                if (window.scrollY > 1200) {
                    button.style.display = "block";
                } else {
                    button.style.display = "none";
                }
            }
        });

        // Checklist persistence
        const checkboxes = document.querySelectorAll('#daily-checklist input[type="checkbox"]');
        const taskLabels = document.querySelectorAll('#daily-checklist .task-label[contenteditable]');
        const today = new Date().toDateString();
        const storageKey = `routine-checklist-${today}`;
        const textStorageKey = `routine-checklist-text`;

        // Load saved checkbox state
        const savedState = localStorage.getItem(storageKey);
        if (savedState) {
            try {
                const state: Record<string, boolean> = JSON.parse(savedState);
                checkboxes.forEach(checkbox => {
                    const taskId = checkbox.dataset.task;
                    if (taskId && state[taskId]) {
                        checkbox.checked = true;
                    }
                });
            } catch (e) {
                console.error('Error loading checklist state:', e);
            }
        }

        // Load saved text
        const savedText = localStorage.getItem(textStorageKey);
        if (savedText) {
            try {
                const textState: Record<string, string> = JSON.parse(savedText);
                taskLabels.forEach(label => {
                    const taskId = label.dataset.task;
                    if (taskId && textState[taskId]) {
                        label.textContent = textState[taskId];
                    }
                });
            } catch (e) {
                console.error('Error loading checklist text:', e);
            }
        }

        // Save checkbox state on change
        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', () => {
                const state: Record<string, boolean> = {};
                checkboxes.forEach(cb => {
                    const taskId = cb.dataset.task;
                    if (taskId) {
                        state[taskId] = cb.checked;
                    }
                });
                localStorage.setItem(storageKey, JSON.stringify(state));
            });
        });

        // Save text on edit
        taskLabels.forEach(label => {
            label.addEventListener('blur', () => {
                const textState: Record<string, string> = {};
                taskLabels.forEach(l => {
                    const taskId = l.dataset.task;
                    if (taskId) {
                        textState[taskId] = l.textContent || '';
                    }
                });
                localStorage.setItem(textStorageKey, JSON.stringify(textState));
            });

            // Prevent Enter from creating new line, save on Enter
            label.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    label.blur();
                }
            });
        });

        // Reset button (optional - can be added later if needed)
        // Check if it's a new day and reset if needed
        const lastReset = localStorage.getItem('routine-checklist-last-reset');
        if (lastReset !== today) {
            // Clear old checklists (keep only today's)
            Object.keys(localStorage).forEach(key => {
                if (key.startsWith('routine-checklist-') && !key.endsWith(today) && key !== 'routine-checklist-last-reset' && key !== textStorageKey) {
                    localStorage.removeItem(key);
                }
            });
            localStorage.setItem('routine-checklist-last-reset', today);
        }
    })
</script>

<style>
    .routine-section {
        margin-top: 2rem;
    }

    .checklist-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .checklist-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem 1.5rem;
        background-color: var(--data-row-black);
        border-radius: 4px;
        border: 1px solid var(--table-white-border);
        transition: all 0.3s ease;
        position: relative;
    }

    .checklist-item:hover {
        background-color: #222222;
        border-color: var(--blue-shade);
    }

    .checklist-item.task-item {
        border-left: 4px solid var(--blue-shade);
        font-size: 16px;
        font-weight: 500;
    }

    .checklist-item.task-item-orange {
        border-left-color: hsla(28, 85%, 55%, 0.75);
    }

    .checklist-item.task-item-orange:hover {
        border-color: hsla(28, 85%, 55%, 0.75);
    }

    .checklist-item.task-item-orange .task-label:focus {
        background-color: hsla(28, 85%, 55%, 0.15);
        border-color: hsla(28, 85%, 55%, 0.75);
    }

    .checklist-item.minor-item {
        border-left: 2px solid var(--table-white-border);
        font-size: 14px;
        font-weight: 400;
        opacity: 0.75;
        padding: 0.75rem 1.25rem;
    }

    .checklist-item input[type="checkbox"] {
        display: none;
    }

    .checkmark {
        position: relative;
        width: 24px;
        height: 24px;
        min-width: 24px;
        border: 2px solid var(--table-white-border);
        border-radius: 4px;
        background-color: var(--background-black);
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .checklist-item.task-item .checkmark {
        width: 28px;
        height: 28px;
        min-width: 28px;
        border-width: 2px;
        border-color: var(--blue-shade);
    }

    .checklist-item.minor-item .checkmark {
        width: 20px;
        height: 20px;
        min-width: 20px;
        border-width: 1.5px;
    }

    .checklist-item input[type="checkbox"]:checked + .checkmark {
        background-color: var(--blue-shade);
        border-color: var(--blue-shade);
    }

    .checklist-item input[type="checkbox"]:checked + .checkmark::after {
        content: '✓';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: var(--text-white-header);
        font-size: 16px;
        font-weight: bold;
    }

    .checklist-item.task-item input[type="checkbox"]:checked + .checkmark::after {
        font-size: 18px;
    }

    .checklist-item.minor-item input[type="checkbox"]:checked + .checkmark::after {
        font-size: 14px;
    }

    .checklist-item.task-item-orange .checkmark {
        border-color: hsla(28, 85%, 55%, 0.75);
    }

    .checklist-item.task-item-orange input[type="checkbox"]:checked + .checkmark {
        background-color: hsla(28, 85%, 55%, 0.75);
        border-color: hsla(28, 85%, 55%, 0.75);
    }

    .checklist-item input[type="checkbox"]:checked ~ .task-label,
    .checklist-item input[type="checkbox"]:checked ~ .task-content .task-label {
        text-decoration: line-through;
        opacity: 0.6;
    }

    .task-label {
        flex: 1;
        color: var(--text-white-body);
        cursor: text;
        outline: none;
        padding: 2px 4px;
        border-radius: 2px;
        transition: all 0.2s ease;
        min-height: 1.2em;
    }

    .task-label:focus {
        background-color: rgba(242, 55%, 40%, 0.1);
        border: 1px solid var(--blue-shade);
        padding: 1px 3px;
    }

    .task-label:empty:before {
        content: attr(data-placeholder);
        color: var(--text-white-body);
        opacity: 0.5;
    }

    .checklist-item.task-item .task-label {
        color: var(--text-white-header);
        font-weight: 500;
    }

    .checklist-item.minor-item .task-label {
        color: var(--text-white-body);
        font-style: italic;
    }

    .checklist-item input[type="checkbox"]:checked ~ .task-label:focus,
    .checklist-item input[type="checkbox"]:checked ~ .task-content .task-label:focus {
        text-decoration: line-through;
        opacity: 0.8;
    }

    .task-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .task-details {
        margin-top: 4px;
    }

    .task-details summary {
        cursor: pointer;
        color: var(--text-white-body);
        font-size: 13px;
        opacity: 0.85;
        list-style: none;
        position: relative;
        padding-right: 1rem;
    }

    .task-details summary::marker,
    .task-details summary::-webkit-details-marker {
        display: none;
    }

    .task-details summary::after {
        content: '▼';
        position: absolute;
        right: 0;
        top: 2px;
        font-size: 10px;
        transition: transform 0.3s;
    }

    .task-details[open] summary::after {
        transform: rotate(180deg);
    }

    .stretch-list {
        margin: 8px 0 0 1rem;
        padding-left: 1rem;
        color: var(--text-white-body);
        font-size: 14px;
        line-height: 1.6;
    }

    .smoothie-details {
        margin-top: 12px;
    }

    .smoothie-details summary {
        cursor: pointer;
        color: var(--text-white-header);
        font-weight: 600;
        padding: 8px 0;
        list-style: none;
        position: relative;
        padding-right: 1.5rem;
    }

    .smoothie-details summary::marker,
    .smoothie-details summary::-webkit-details-marker {
        display: none;
    }

    .smoothie-details summary::after {
        content: '▼';
        position: absolute;
        right: 0;
        top: 8px;
        font-size: 12px;
        transition: transform 0.3s;
    }

    .smoothie-details[open] summary::after {
        transform: rotate(180deg);
    }

    .ingredients-list {
        list-style: none;
        padding: 0;
        margin: 12px 0 0 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .ingredients-list li {
        padding: 8px 12px;
        background-color: var(--background-black);
        border-radius: 4px;
        border: 1px solid var(--table-white-border);
        color: var(--text-white-body);
    }

    .ingredients-list li.optional {
        font-style: italic;
        opacity: 0.8;
        margin-top: 4px;
    }

    .rhythm-item {
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background-color: var(--data-row-black);
        border-radius: 4px;
        border: 1px solid var(--table-white-border);
        transition: all 0.3s ease;
    }

    .rhythm-item:hover {
        background-color: #222222;
        border-color: var(--blue-shade);
    }

    .rhythm-item h3 {
        margin: 0 0 4px 0;
        color: var(--text-white-header);
    }

    .rhythm-item p {
        margin: 0;
        color: var(--text-white-body);
    }

    .rules-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .rules-list li {
        padding: 1rem 1.5rem;
        margin-bottom: 1rem;
        background-color: var(--data-row-black);
        border-radius: 4px;
        border: 1px solid var(--table-white-border);
        border-left: 4px solid var(--blue-shade);
        transition: all 0.3s ease;
    }

    .rules-list li:hover {
        background-color: #222222;
        border-color: var(--blue-shade);
        transform: translateX(4px);
    }

    @media only screen and (max-width: 600px) {
        .checklist-item {
            padding: 1rem 1.25rem;
        }

        .checklist-item.task-item {
            font-size: 15px;
        }

        .checklist-item.minor-item {
            font-size: 13px;
            padding: 0.65rem 1rem;
        }
    }
</style>

