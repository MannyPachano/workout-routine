---
import "../style.scss";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>manny workout plan</title>
</head>
<body>
    <div class="container">
        <a href="#top" id="back-to-top" class="back-to-top">^</a>
        <a href="/routine" class="link">life routine →</a>
        <section class="mobility-section">
            <details class="mobility-box">
                <summary>mobility exercises</summary>
                <ul>
                    <li>pigeon stretch</li>
                    <li>90/90 lift offs</li>
                    <li>frog stretch</li>
                    <li>internal hip lift offs</li>
                    <li>nordic curl stretch</li>
                    <li>single leg nordic curl pulls</li>
                    <li>ql raises</li>
                    <li>split work</li>
                    <li>slow sumo squats</li>
                </ul>
            </details>
        </section>
        <section id="phase-1" class="workout-boxes">
            <h3>day 1: chest & triceps</h3>
            <div class="workout-container-tables">
                <table class="routine-table-has-reps">
                    <thead>
                        <tr>
                            <th>exercise</th>
                            <th>sets</th>
                            <th>reps</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>rotational single-arm med ball wall throws</td>
                            <td>3 sets</td>
                            <td>3–6 / arm/set (max quality)</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">DB Press · Incline DB Press</td>
                            <td>6 sets</td>
                            <td>flat 6–10 · incline 8–12</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Thumb-up Bent Over DB Lateral Raises · Scapula Work</td>
                            <td>6 sets</td>
                            <td>laterals 12–20 · scap 12–20</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">Tricep Pushdowns · Tricep Rope Pushdowns</td>
                            <td>6 sets</td>
                            <td>straight bar 8–12 · rope 10–15</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Cable Hand Flexions · Kettlebell Wrist Rotations</td>
                            <td>6 sets</td>
                            <td>flexions 15–25 · rotations 12–20</td>
                        </tr>
                        <tr>
                            <td>Neck Flexor Circuit</td>
                            <td>3 sets</td>
                            <td>30 / station (or time)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 2: back & biceps</h3>
            <div class="workout-container-tables">
                <table class="routine-table-has-reps">
                    <thead>
                        <tr>
                            <th>exercise</th>
                            <th>sets</th>
                            <th>reps</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>medicine ball slam to sprawl</td>
                            <td>3 sets</td>
                            <td>3–6 / set (max quality)</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Cable Rows · Wrist Curls</td>
                            <td>3 sets</td>
                            <td>rows 6–12 · curls 15–25</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Cable Pull Downs · Plate Pinches</td>
                            <td>3 sets</td>
                            <td>pull downs 8–12 · pinches 30–45 sec</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Bicep Curls · Kettlebell Wrist Rotations</td>
                            <td>3 sets</td>
                            <td>curls 8–12 · rotations 12–20 / direction</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Reverse Barbell Curls · Barbell Finger Curls</td>
                            <td>3 sets</td>
                            <td>reverse curls 8–12 · finger curls 15–25</td>
                        </tr>
                        <tr>
                            <td>Rear Neck Circuit · Flexions · Rotations · Lateral Flexions</td>
                            <td>3 sets</td>
                            <td>30 / station</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 3: quads</h3>
            <div class="workout-container-tables">
                <table class="routine-table-has-reps">
                    <thead>
                        <tr>
                            <th>exercise</th>
                            <th>sets</th>
                            <th>reps</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>squat jumps</td>
                            <td>3 sets</td>
                            <td>5–10</td>
                        </tr>
                        <tr>
                            <td>heiden jumps</td>
                            <td>3 sets</td>
                            <td>3–6 / direction/set</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Pistol Squats · Reverse Wrist Curls</td>
                            <td>3 sets</td>
                            <td>pistols 5–10 / leg · curls 15–25</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">Reverse Nordic Curls · Kettlebell Radial Deviations</td>
                            <td>3 sets</td>
                            <td>nordics 5–10 · deviations 12–20 / direction</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="3" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">1-Leg Leg Press · Rubber Band Finger Openers</td>
                            <td>3 sets</td>
                            <td>leg press 8–12 / leg · openers 15–25</td>
                        </tr>
                        <tr>
                            <td>tibia raises</td>
                            <td>3 sets</td>
                            <td>12–20</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 4: arms</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>band-resisted heavy kettlebell swings</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">triceps</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">traps</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">biceps</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">hands</td>
                            <td>3 sets</td>
                        </tr>
                        <tr>
                            <td>lateral neck (chin down)</td>    
                            <td>3 sets</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 5: shoulders</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>dumbbell push jerk</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">front delts</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">traps</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">side delts</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">forearms</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">rear delts</td>
                            <td>3 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">hands</td>
                            <td>3 sets</td>
                        </tr>

                    </tbody>
                </table>
            </div>
            <h3>day 6: glutes & hamstrings</h3>
            <div class="workout-container-tables">
                <table class="routine-table-has-reps">
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                            <th>reps</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>single-leg broad jumps</td>
                            <td>3 sets</td>
                            <td>3–6 / leg/set</td>
                        </tr>
                        <tr>
                            <td>tibia raises</td>
                            <td>3 sets</td>
                            <td>12–20</td>
                        </tr>
                        <tr>
                            <td>hip thrust · lateral leg raises</td>
                            <td>6 sets</td>
                            <td>thrust 6–12 · laterals 12–20</td>
                        </tr>
                        <tr>
                            <td>deadlifts · glute-ham raises · hamstring curls</td>
                            <td>9 sets</td>
                            <td>DL 6–10 · GHR 6–12 · curl 8–15</td>
                        </tr>
                        <tr>
                            <td>calf raises · seated calf raises</td>   
                            <td>3 sets</td>
                            <td>10–15 standing · 15–25 seated optional</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</body>
</html>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // scroll to top
        window.addEventListener("scroll", () => {
            const button = document.getElementById("back-to-top");
            if (button) {
                if (window.scrollY > 1200) {
                    button.style.display = "block";
                } else {
                    button.style.display = "none";
                }
            }
        });
            
        // section toggle
        const mobilityDetails = document.querySelectorAll('.mobility-boxes details');
        mobilityDetails.forEach((targetDetail) => {
            targetDetail.addEventListener('click', () => {
                mobilityDetails.forEach((detail) => {
                if (detail !== targetDetail) detail.removeAttribute('open');
                });
            });
        });
    })
  </script>
  