---
import "../style.scss";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>manny workout plan</title>
</head>
<body>
    <div class="container">
        <a href="#top" id="back-to-top" class="back-to-top">^</a>
        <a href="/routine" class="link">life routine →</a>
        <section class="mobility-section">
            <details class="mobility-box">
                <summary>mobility exercises</summary>
                <ul>
                    <li>pigeon stretch</li>
                    <li>90/90 lift offs</li>
                    <li>frog stretch</li>
                    <li>internal hip lift offs</li>
                    <li>nordic curl stretch</li>
                    <li>single leg nordic curl pulls</li>
                    <li>ql raises</li>
                    <li>split work</li>
                    <li>slow sumo squats</li>
                </ul>
            </details>
        </section>
        <section id="phase-1" class="workout-boxes">
            <h3>day 1: chest & triceps</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">chest</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">traps</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">triceps</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">hands</td>
                            <td>9 sets</td>
                        </tr>
                        <tr>
                            <td>front neck</td>
                            <td>3 sets</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 2: back & biceps</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>          
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">back</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">rear delts</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">biceps</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">hands</td>
                            <td>9 sets</td>
                        </tr>
                        <tr>
                            <td>rear neck</td>
                            <td>3 sets</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 3: quads</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>squat jumps</td>    
                            <td>3 sets</td>
                        </tr>
                        <tr>
                            <td>quads (pistols, nordics, 1-leg leg press, zercher squats)</td>
                            <td>12 sets</td>
                        </tr>
                        <tr>
                            <td>tibia raises</td>   
                            <td>3 sets</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 4: arms</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">triceps</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">traps</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">biceps</td>
                            <td>9 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">hands</td>
                            <td>9 sets</td>
                        </tr>
                        <tr>
                            <td>lateral neck (chin down)</td>    
                            <td>3 sets</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <h3>day 5: shoulders</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">front delts</td>
                            <td>6 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">traps</td>
                            <td>6 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">side delts</td>
                            <td>6 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">forearms</td>
                            <td>6 sets</td>
                        </tr>
                        <tr class="superset-group-start">
                            <td colspan="2" class="superset-label">superset</td>
                        </tr>
                        <tr class="superset-exercise">
                            <td class="superset-exercise-name">rear delts</td>
                            <td>6 sets</td>
                        </tr>
                        <tr class="superset-exercise superset-group-end">
                            <td class="superset-exercise-name">hands</td>
                            <td>6 sets</td>
                        </tr>

                    </tbody>
                </table>
            </div>
            <h3>day 6: glutes & hamstrings</h3>
            <div class="workout-container-tables">
                <table>
                    <thead>
                        <tr>
                            <th>exercise</th>  
                            <th>sets</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>plyometrics</td>
                            <td>9 sets</td>
                        </tr>
                        <tr>
                            <td>glutes (sumo deadlifts, hip thrust, lat leg raises)</td>
                            <td>9 sets</td>
                        </tr>
                        <tr>
                            <td>hamstrings (deadlifts, glute-ham, hamstring curls)</td>
                            <td>9 sets</td>
                        </tr>
                        <tr>
                            <td>calves</td>   
                            <td>3 sets</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</body>
</html>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // scroll to top
        window.addEventListener("scroll", () => {
            const button = document.getElementById("back-to-top");
            if (button) {
                if (window.scrollY > 1200) {
                    button.style.display = "block";
                } else {
                    button.style.display = "none";
                }
            }
        });
            
        // section toggle
        const mobilityDetails = document.querySelectorAll('.mobility-boxes details');
        mobilityDetails.forEach((targetDetail) => {
            targetDetail.addEventListener('click', () => {
                mobilityDetails.forEach((detail) => {
                if (detail !== targetDetail) detail.removeAttribute('open');
                });
            });
        });
    })
  </script>
  